# Gemini API キー（必須）
# https://aistudio.google.com/app/apikey で取得
GEMINI_API_KEY=your_gemini_api_key_here

# 使用するGeminiモデル（デフォルト: gemini-2.0-flash）
# GEMINI_MODEL=gemini-2.0-flash

# データベースの保存先（デフォルト: data/gikai.db）
# DB_PATH=data/gikai.db

# スクレイピングの待機時間（秒）サーバー負荷軽減のため変更しないことを推奨
# REQUEST_DELAY=2.0

# ブラウザをヘッドレスで起動するか（false にすると画面が表示される）
# HEADLESS=true

# Geminiに送るテキストの最大文字数（コスト削減）
# GEMINI_MAX_CHARS=3000
