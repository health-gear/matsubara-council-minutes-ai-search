# 環境変数（APIキーを含むため必ずgitignore）
.env

# データベース（サイズが大きいためgitignore）
data/*.db
data/*.db-wal
data/*.db-shm

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# 仮想環境
venv/
env/
.venv/
.env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Playwright
playwright-report/
test-results/

# デバッグ・開発用スクリプト（本番には不要）
debug_*.py
test_*.py
